# ===== LLM / Embedding / Rerank (通义 DashScope) =====
DASHSCOPE_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_SMALL=qwen-turbo
LLM_MODEL_LARGE=qwen-plus
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024
RERANK_MODEL=gte-rerank-v2

# ===== 基础设施 =====
# 注：宿主机端口已错开常用端口，避免与本机其它服务冲突
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=devsupport
MYSQL_PASSWORD=devsupport123
MYSQL_DB=devsupport

MILVUS_URI=http://localhost:19531
MILVUS_COLLECTION=knowledge_chunk

REDIS_URL=redis://localhost:6380/0

# ===== 认证 =====
JWT_SECRET=change-me-in-production-please
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720

# ===== 业务阈值 =====
INTENT_CONFIDENCE_THRESHOLD=0.6
RAG_SCORE_THRESHOLD=0.3
TOOL_TIMEOUT_SECONDS=3
SEMANTIC_CACHE_SIM_THRESHOLD=0.95

# ===== 其它 =====
APP_ENV=dev
LOG_LEVEL=INFO
